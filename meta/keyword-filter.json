  "meta": {
    "schema_version": "2.0.0",
    "schema": "keyword-filter",
    "project": "CanadaScanada",
    "last_updated": "2026-05-27",
    "logic": "A story must match AT LEAST ONE term from 'actors_any' AND at least one term from ANY category group to pass the filter. Single-dimension matches (actor only, or category only) are discarded as too noisy. All matching is case-insensitive. Terms are checked against title + description/summary fields in the feed item.",
    "note": "This file drives the zero-LLM filtering step. No tokens consumed here. Add terms freely — the cost of a false positive is one extra item in the review queue; the cost of a false negative is a missed story."
  },
